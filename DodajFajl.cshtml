@model GimnazijaKM.Models.FajlFormaViewModel

@{
    ViewBag.Title = "Dodaj fajl";
    Layout = "~/Views/Shared/_Layout2.cshtml";
}

<h2>Dodaj fajl</h2>

@using (Html.BeginForm("DodajFajl", "Home", FormMethod.Post, new { enctype = "multipart/form-data" }))
{
    @Html.AntiForgeryToken()

    <div class="form-group">
        @Html.LabelFor(model => model.NoviFajl.Naziv)
        @Html.TextBoxFor(model => model.NoviFajl.Naziv, new { @class = "form-control" })
        @Html.ValidationMessageFor(model => model.NoviFajl.Naziv)
    </div>

    <div class="form-group">
        @Html.LabelFor(model => model.NoviFajl.Tip)
        @Html.TextBoxFor(model => model.NoviFajl.Tip, new { @class = "form-control" })
        @Html.ValidationMessageFor(model => model.NoviFajl.Tip)
    </div>

    <div class="form-group">
        <label>Izaberi fajl</label>
        <input type="file" name="FajlUpload" class="form-control" />
        @Html.ValidationMessageFor(model => model.NoviFajl.Naziv)
    </div>

    <button type="submit" class="btn btn-success">Dodaj fajl</button>
}

<h3>Vidi fajlovi</h3>
<table class="table">
    <thead>
        <tr>
            <th>Naslov</th>
            <th>Format</th>
            <th>Link</th>
            <th>Edit/Delete</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var fajl in Model.SviFajlovi)
        {
            <tr>
                <td>@fajl.Naziv</td>
                <td>@fajl.Tip</td>
                <td><a href="@Url.Content(fajl.Putanja)">Preuzmi</a></td>
                <td>
                    <a href="@Url.Action("AzurirajFajl", "Home", new { id = fajl.Id })" class="btn btn-warning">Ažuriraj</a>
                    <a href="@Url.Action("IzbrisiFajl", "Home", new { id = fajl.Id })" class="btn btn-danger">Izbriši</a>
                </td>

            </tr>
        }
    </tbody>
</table>
