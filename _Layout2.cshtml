<!DOCTYPE html>
<html lang="sr">
<head>
    <meta charset="utf-8" />
    <title>@ViewBag.Title - Admin Panel</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <style>
        body {
            overflow-x: hidden;
        }

        #sidebar-wrapper {
            min-width: 250px;
            max-width: 250px;
            height: 100vh;
            position: fixed;
            transition: all 0.3s;
            overflow-y: auto;
        }

        #page-content-wrapper {
            margin-left: 250px;
            transition: all 0.3s;
        }

        #wrapper.toggled #sidebar-wrapper {
            margin-left: -250px;
        }

        #wrapper.toggled #page-content-wrapper {
            margin-left: 0;
        }

        .sidebar-footer {
            position: absolute;
            bottom: 0;
            width: 100%;
        }
    </style>
</head>
<body>

    <div class="d-flex" id="wrapper">

        <!-- Sidebar -->
        <div class="border-end bg-light" id="sidebar-wrapper">
            <div class="sidebar-heading bg-primary text-white text-center py-3 fs-5">Admin Panel</div>
            <div class="list-group list-group-flush">

                @Html.ActionLink("Administracija", "Administracija", "Home", null, new { @class = "list-group-item list-group-item-action p-3" })
                @Html.ActionLink("Vesti", "KreirajVest", "Home", null, new { @class = "list-group-item list-group-item-action p-3" })

                <div class="accordion" id="accordionSidebar">

                    <!-- Prvi Accordion -->
                    <div class="accordion-item border-0">
                        <h2 class="accordion-header" id="headingFajlRaspored">
                            <button class="accordion-button collapsed px-3 py-2 bg-light" type="button"
                                    data-bs-toggle="collapse" data-bs-target="#collapseFajlRaspored"
                                    aria-expanded="false" aria-controls="collapseFajlRaspored">
                                Dodaj Fajl/Raspored
                            </button>
                        </h2>
                        <div id="collapseFajlRaspored" class="accordion-collapse collapse" aria-labelledby="headingFajlRaspored" data-bs-parent="#accordionSidebar">
                            <div class="accordion-body p-0">
                                <ul class="list-group list-group-flush">
                                    <li class="list-group-item px-4 py-2">@Html.ActionLink("Dodaj Fajl", "DodajFajl", "Home", null, new { @class = "text-decoration-none" })</li>
                                    <li class="list-group-item px-4 py-2">@Html.ActionLink("Raspored Casova", "UbaciRaspored", "Home", null, new { @class = "text-decoration-none" })</li>
                                </ul>
                            </div>
                        </div>
                    </div>

                    <!-- Drugi Accordion -->
                    <div class="accordion-item border-0">
                        <h2 class="accordion-header" id="headingProjekti">
                            <button class="accordion-button collapsed px-3 py-2 bg-light" type="button"
                                    data-bs-toggle="collapse" data-bs-target="#collapseProjekti"
                                    aria-expanded="false" aria-controls="collapseProjekti">
                                Додај Пројекте
                            </button>
                        </h2>
                        <div id="collapseProjekti" class="accordion-collapse collapse" aria-labelledby="headingProjekti" data-bs-parent="#accordionSidebar">
                            <div class="accordion-body p-0">
                                <ul class="list-group list-group-flush">
                                    <li class="list-group-item px-4 py-2">@Html.ActionLink("IT/Smer", "Projekti", "Home", null, new { @class = "text-decoration-none" })</li>
                                    <li class="list-group-item px-4 py-2">@Html.ActionLink("Jezicki/Smer", "DodajJezickiSmer", "Home", null, new { @class = "text-decoration-none" })</li>
                                    <li class="list-group-item px-4 py-2">@Html.ActionLink("Matematicki/Smer", "DodajMatematickiSmer", "Home", null, new { @class = "text-decoration-none" })</li>
                                </ul>
                            </div>
                        </div>
                    </div>

                </div>

                @Html.ActionLink("Dolazeći Događaji", "KreirajDogadjaj", "Home", null, new { @class = "list-group-item list-group-item-action p-3" })
                @Html.ActionLink("Vidi Poruke", "VidiPoruku", "Home", null, new { @class = "list-group-item list-group-item-action p-3" })
                @Html.ActionLink("Dodaj Clanove Aktiva", "UbaciTim", "Home", null, new { @class = "list-group-item list-group-item-action p-3" })
                @Html.ActionLink("List Clanova Timova i Aktiva", "ListaTimovaAdmin", "Home", null, new { @class = "list-group-item list-group-item-action p-3" })
                @Html.ActionLink("Maturanti", "DodajMaturante", "Home", null, new { @class = "list-group-item list-group-item-action p-3" })
                @Html.ActionLink("Dodaj Javnu Nabavku", "DodajJavneNabavke", "Home", null, new { @class = "list-group-item list-group-item-action p-3" })
                @Html.ActionLink("Dodaj Letopis", "DodajLetopis", "Home", null, new { @class = "list-group-item list-group-item-action p-3" })
                @Html.ActionLink("Dodaj Ekskurzije", "DodajEkskurziju", "Home", null, new { @class = "list-group-item list-group-item-action p-3" })
                @Html.ActionLink("Dodaj Slider", "DodajSlider", "Home", null, new { @class = "list-group-item list-group-item-action p-3" })

            </div>

            <!-- Logout dugme -->
            <div class="sidebar-footer border-top text-center py-3 bg-light">
                @Html.ActionLink("Logout", "Index", "Home", null, new { @class = "btn btn-outline-danger btn-sm w-75" })
            </div>
        </div>

        <!-- Page content -->
        <div id="page-content-wrapper" class="w-100">

            <nav class="navbar navbar-expand-lg navbar-light bg-light border-bottom">
                <div class="container-fluid">
                    <button class="btn btn-primary" id="menu-toggle">☰</button>
                </div>
            </nav>

            <div class="container-fluid mt-4">
                @RenderBody()
            </div>

        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        document.getElementById("menu-toggle").addEventListener("click", function () {
            document.getElementById("wrapper").classList.toggle("toggled");
        });
    </script>

</body>
</html>
