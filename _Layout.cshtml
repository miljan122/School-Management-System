<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title - My ASP.NET Application</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />


    @Styles.Render("~/Content/css")
    @Scripts.Render("~/bundles/modernizr")
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark" style="background: #0e1980 ">
        <div class="container">
            <!-- Logo s leva -->
            <!-- Toggler za mobilnu verziju -->
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>

            <!-- Navigacija -->
            <div class="collapse navbar-collapse justify-content-center" id="navbarNav">
                <ul class="navbar-nav">
                    <!-- Linkovi u sredini -->
                    <li class="nav-item">
                        @Html.ActionLink("Почетна", "Index", "Home", new { area = "" }, new { @class = "nav-link", style = "color: #ffaa00; font-weight: 700;" })
                    </li>
                    <li class="nav-item">
                        @Html.ActionLink("О нама", "About", "Home", new { area = "" }, new { @class = "nav-link", style = "color: #ffaa00; font-weight: 700;" })
                    </li>
                    <li class="nav-item">
                        @Html.ActionLink("Kонтакт", "Contact", "Home", new { area = "" }, new { @class = "nav-link", style = "color: #ffaa00; font-weight: 700;" })
                    </li>

                    <!-- Dropdowns -->
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" href="#" id="dropdown1" role="button" data-bs-toggle="dropdown" aria-expanded="false" style="color: #ffaa00; font-weight: 700; ">
                            Гимназијалац
                        </a>
                        <ul class="dropdown-menu" aria-labelledby="dropdown1">
                            <li>@Html.ActionLink("Матуранти", "Maturanti", "Home", new { area = "" }, new { @class = "dropdown-item", style = "color: #ffaa00; font-weight: 700;" })</li>
                            <li>@Html.ActionLink("Мост Математике", "MostMatematike", "Home", new { area = "" }, new { @class = "dropdown-item", style = "color: #ffaa00; font-weight: 700;" })</li>
                            <li>@Html.ActionLink("Екскурзија", "Ekskurzija", "Home", new { area = "" }, new { @class = "dropdown-item", style = "color: #ffaa00; font-weight: 700;" })</li>

                        </ul>
                    </li>

                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" href="#" id="dropdown1" role="button" data-bs-toggle="dropdown" aria-expanded="false" style="color: #ffaa00; font-weight: 700;">
                            Летопис
                        </a>
                        <ul class="dropdown-menu" aria-labelledby="dropdown1">
                            @Html.Action("LetopisiMeni", "Home")
                        </ul>
                    </li>



                    <li class="nav-item">
                        @Html.ActionLink("Јавне Набавке", "JavnaNabavka", "Home", new { area = "" }, new { @class = "nav-link", style = "color: #ffaa00; font-weight: 700;" })
                    </li>
                    <li class="nav-item">
                        @Html.ActionLink("Распоред часова", "PogledajRaspored", "Home", new { area = "" }, new { @class = "nav-link", style = "color: #ffaa00; font-weight: 700;" })
                    </li>
                    <li class="nav-item">
                        @Html.ActionLink("Документа", "Dokumenta", "Home", new { area = "" }, new { @class = "nav-link", style = "color: #ffaa00; font-weight: 700;" })
                    </li>
                    <li class="nav-item">
                        @Html.ActionLink("Timovi i Aktivi", "Timovi", "Home", new { area = "" }, new { @class = "nav-link", style = "color: #ffaa00; font-weight: 700;" })
                    </li>

                    <!-- Add other dropdowns here -->
                </ul>
            </div>

            <!-- Login na desnoj strani -->
            <div class="d-flex">
                <a class="nav-link" style=" color: #ffaa00; font-weight: 700;" href="@Url.Action("Login", "Home" ,new { @class = "nav-link" })">Login</a>
            </div>
        </div>
    </nav>



    <div class="container body-content">
        @RenderBody()

        <hr />
        <footer class="text-white mt-5" style="background-color: #ffc34d;">
            <div class="container py-4">
                <div class="row">
                    <!-- Logo i naziv škole -->
                    <div class="col-md-4 mb-4">
                        <img src="/Content/slike/Gim Logo.png" alt="Logo" style="height: 80px;">
                        <h5 class="mt-2" style="font-family: 'Bookman Old Style'; color: #003366;">Гимназија К.М</h5>
                        <p class="text-white-50">Знање, труд и успех!</p>
                    </div>

                    <!-- Navigacija -->
                    <div class="col-md-4 mb-4">
                        <h5 style="color: #003366;">Навигација</h5>
                        <ul class="list-unstyled">
                            <li><a href="@Url.Action("Index", "Home")" class="text-white text-decoration-none">Почетна</a></li>
                            <li><a href="@Url.Action("About", "Home")" class="text-white text-decoration-none">О нама</a></li>
                            <li><a href="@Url.Action("Contact", "Home")" class="text-white text-decoration-none">Контакт</a></li>
                            <li><a href="@Url.Action("Login", "Account")" class="text-white text-decoration-none">Пријава</a></li>
                        </ul>
                    </div>

                    <!-- Kontakt informacije -->
                    <div class="col-md-4 mb-4">
                        <h5 style="color: #003366;">Контакт информације</h5>
                        <ul class="list-unstyled">
                            <li><i class="fas fa-map-marker-alt"></i> Косовска Митровица, Србија</li>
                            <li><i class="fas fa-phone"></i> +381 64 1234567</li>
                            <li><i class="fas fa-envelope"></i> kontakt@gimnazija.rs</li>
                        </ul>
                    </div>
                </div>

                <div class="row justify-content-center">
                    <!-- Ikonice društvenih mreža -->
                    <div class="col-md-4 text-center">
                        <h5 style="color: #003366;">Прати нас</h5>
                        <a href="#" class="text-white me-3"><i class="fab fa-facebook fa-2x"></i></a>
                        <a href="#" class="text-white me-3"><i class="fab fa-instagram fa-2x"></i></a>
                        <a href="#" class="text-white me-3"><i class="fab fa-twitter fa-2x"></i></a>
                        <a href="#" class="text-white"><i class="fab fa-youtube fa-2x"></i></a>
                    </div>
                </div>

                <hr class="border-light" />
                <div class="row justify-content-between">
                    <div class="col-md-6 text-center text-white-50">
                        &copy; @DateTime.Now.Year - Гимназија Кoсовска митровица. Сва права задржана.
                    </div>
                    <div class="col-md-6 text-center text-white-50">
                        <a href="#top" class="text-white-50 text-decoration-none">Врати се на врх</a>
                    </div>
                </div>
            </div>
        </footer>
    </div>


    <!-- Učitavanje Bootstrap JS sa Popper.js -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/js/bootstrap.bundle.min.js"></script>

    @Scripts.Render("~/bundles/jquery")
    @RenderSection("scripts", required: false)
</body>
</html>
