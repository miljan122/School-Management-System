@model List<GimnazijaKM.Models.ContactMessage>
@{
    ViewBag.Title = "VidiPoruku";
    Layout = "~/Views/Shared/_Layout2.cshtml";
}



<table class="table table-striped table-bordered" style="table-layout: fixed; width: 100%;">
    <thead>
        <tr>
            <th>ID</th>
            <th>Пуно име</th>
            <th>Емаил</th>
            <th>Тема</th>
            <th>Порука</th>
            <th>Послато</th>
            <th>Акција</th> <!-- Nova kolona -->
        </tr>
    </thead>
    <tbody>
        @foreach (var poruka in Model)
        {
            <tr>
                <td>@poruka.ID</td>
                <td>@poruka.PunoIme</td>
                <td>@poruka.Email</td>
                <td style="word-wrap: break-word;">@poruka.Tema</td>
                <td style="word-wrap: break-word;">@poruka.Poruka</td>
                <td>@poruka.Poslato.ToString("dd.MM.yyyy HH:mm")</td>
                <td>
                    @using (Html.BeginForm("IzbrisiPoruku", "Home", FormMethod.Post, new { onsubmit = "return confirm('Да ли сте сигурни да желите да избришете ову поруку?');" }))
                    {
                        @Html.AntiForgeryToken()
                        @Html.Hidden("id", poruka.ID)
                        <button type="submit" class="btn btn-danger btn-sm">Обриши</button>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>

@if (TempData["Message"] != null)
{
    <div class="alert alert-info" style="margin-top: 15px;">
        @TempData["Message"]
    </div>
}
