@model GimnazijaKM.Models.Letopi

@{
    ViewBag.Title = Model.Naslov ?? "Детаљи летописа";
}

<div class="container my-5">

    <style>
        /* Crne strelice za Bootstrap carousel */
        #pdfCarousel .carousel-control-prev-icon,
        #pdfCarousel .carousel-control-next-icon {
            filter: invert(0);
            background-color: rgba(0, 0, 0, 0.5);
            border-radius: 50%;
            width: 2.5rem;
            height: 2.5rem;
        }
    </style>

    <div class="card shadow-lg border-3 border-warning rounded-4">
        <div class="card-header bg-warning text-dark fw-bold fs-3 text-center">
            @Model.Naslov
        </div>
        <div class="card-body px-4 py-3">
            <p class="card-text fs-5 text-secondary">
                <strong>Опис:</strong> @Model.Opis
            </p>
            <p>
                <span class="badge bg-secondary fs-6">
                    Датум уноса: @(Model.DatumUnosa?.ToString("dd.MM.yyyy") ?? "Није доступно")
                </span>
            </p>

            @if (!string.IsNullOrEmpty(Model.PdfPutanja))
            {
                <hr class="my-4" />
               

                <div id="pdfCarousel" class="carousel slide mx-auto border border-3 border-warning rounded-4 shadow-lg" style="max-width:900px;" data-bs-ride="carousel">
                    <div class="carousel-inner" id="pdf-carousel-inner">
                        <!-- Dinamički canvas elementi će biti ubačeni ovde -->
                        <div class="text-center my-5" id="pdf-loading">
                            <div class="spinner-border text-warning" role="status">
                                <span class="visually-hidden">Учитавање...</span>
                            </div>
                        </div>
                    </div>

                    <button class="carousel-control-prev" type="button" data-bs-target="#pdfCarousel" data-bs-slide="prev">
                        <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                        <span class="visually-hidden">Претходна</span>
                    </button>
                    <button class="carousel-control-next" type="button" data-bs-target="#pdfCarousel" data-bs-slide="next">
                        <span class="carousel-control-next-icon" aria-hidden="true"></span>
                        <span class="visually-hidden">Следећа</span>
                    </button>
                </div>

                <!-- Dugme za otvaranje PDF-a uvećano -->
                <div class="text-center mt-3">
                    <button class="btn btn-warning fw-bold" data-bs-toggle="modal" data-bs-target="#pdfModal">
                        Отвори PDF
                    </button>
                </div>

                <!-- Modal za PDF -->
                <div class="modal fade" id="pdfModal" tabindex="-1" aria-labelledby="pdfModalLabel" aria-hidden="true">
                    <div class="modal-dialog modal-xl modal-dialog-centered" style="max-width:95%;">
                        <div class="modal-content">
                            <div class="modal-header bg-warning text-dark">
                                <h5 class="modal-title fw-bold" id="pdfModalLabel">@Model.Naslov</h5>
                                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                            </div>
                            <div class="modal-body p-0" style="height:90vh;">
                                <iframe src="@Url.Content(Model.PdfPutanja)" style="width:100%; height:100%;" frameborder="0"></iframe>
                            </div>
                        </div>
                    </div>
                </div>
            }
            else
            {
                <p class="text-muted fst-italic text-center mt-4">Нема PDF документа за приказ.</p>
            }
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/pdf.js/2.14.305/pdf.min.js"></script>
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            var pdfPath = '@Url.Content(Model.PdfPutanja)';
            var loadingDiv = document.getElementById('pdf-loading');
            var carouselInner = document.getElementById('pdf-carousel-inner');

            const pdfjsLib = window['pdfjs-dist/build/pdf'];
            pdfjsLib.GlobalWorkerOptions.workerSrc = 'https://cdnjs.cloudflare.com/ajax/libs/pdf.js/2.14.305/pdf.worker.min.js';

            pdfjsLib.getDocument(pdfPath).promise.then(function(pdf) {
                loadingDiv.style.display = 'none';

                let renderPromises = [];

                for (let pageNum = 1; pageNum <= pdf.numPages; pageNum++) {
                    renderPromises.push(
                        pdf.getPage(pageNum).then(function(page) {
                            var viewport = page.getViewport({ scale: 1.5 });
                            var canvas = document.createElement('canvas');
                            canvas.classList.add('d-block', 'w-100');
                            canvas.style.maxHeight = '80vh';
                            canvas.style.margin = 'auto';

                            var context = canvas.getContext('2d');
                            canvas.height = viewport.height;
                            canvas.width = viewport.width;

                            var renderContext = {
                                canvasContext: context,
                                viewport: viewport
                            };

                            return page.render(renderContext).promise.then(function () {
                                var carouselItem = document.createElement('div');
                                carouselItem.classList.add('carousel-item');
                                if (pageNum === 1) carouselItem.classList.add('active');
                                carouselItem.appendChild(canvas);
                                carouselInner.appendChild(carouselItem);
                            });
                        })
                    );
                }

                return Promise.all(renderPromises);
            }).catch(function(error) {
                loadingDiv.innerHTML = '<p class="text-danger text-center mt-4">Грешка приликом учитавања PDF-а.</p>';
                console.error(error);
            });
        });
    </script>
}
