@model GimnazijaKM.Models.Dogadjaji

@{
    ViewBag.Title = "Delete Event";
    Layout = "~/Views/Shared/_Layout2.cshtml";
}

<h2>Da li ste sigurni da zelite da izbrisete Vest?</h2>

<div>
    <h4>@Model.Ime</h4>
    <p><strong>Datum:</strong> @Model.Datum</p>
    <p><strong>Opis:</strong> @Model.Opis</p>

    @if (!string.IsNullOrEmpty(Model.Slika))
    {
        <p><img src="@Url.Content("~/Content/slike/" + Model.Slika)" width="150" /></p>
    }

    <!-- Begin form for deletion -->
    @using (Html.BeginForm("Delete", "Home", FormMethod.Post))
    {
        @Html.AntiForgeryToken()
        @Html.HiddenFor(model => model.Id)

        <input type="submit" value="Delete" class="btn btn-danger" />
    }

    <br />
    <!-- Cancel link to go back to event creation page -->
    @Html.ActionLink("Cancel", "KreirajDogadjaj", null, new { @class = "btn btn-secondary" })
</div>
