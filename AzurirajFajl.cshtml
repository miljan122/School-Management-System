@model GimnazijaKM.Models.FajlFormaViewModel

@{
    ViewBag.Title = "Ažuriraj fajl";
    Layout = "~/Views/Shared/_Layout2.cshtml";
}

@using (Html.BeginForm("AzurirajFajl", "Home", FormMethod.Post, new { enctype = "multipart/form-data" }))
{
    @Html.AntiForgeryToken()
    @Html.HiddenFor(model => model.NoviFajl.Id) <!-- OVO DODAJ -->

    <div class="card shadow-sm rounded p-4 mt-4" style="max-width: 600px; margin: 0 auto;">
        <h3 class="mb-4 text-center">Ažuriranje fajla</h3>

        <div class="form-group mb-3">
            @Html.LabelFor(model => model.NoviFajl.Naziv, new { @class = "form-label fw-bold" })
            @Html.TextBoxFor(model => model.NoviFajl.Naziv, new { @class = "form-control", placeholder = "Unesite naziv fajla" })
        </div>

        <div class="form-group mb-3">
            @Html.LabelFor(model => model.NoviFajl.Tip, new { @class = "form-label fw-bold" })
            @Html.TextBoxFor(model => model.NoviFajl.Tip, new { @class = "form-control", placeholder = "Unesite tip fajla (PDF, DOCX...)" })
        </div>

        <div class="form-group mb-4">
            <label for="FajlUpload" class="form-label fw-bold">Zameni fajl (opcionalno)</label>
            <input type="file" name="FajlUpload" id="FajlUpload" class="form-control" />
        </div>

        <div class="text-center">
            <button type="submit" class="btn btn-primary px-4">Sačuvaj izmene</button>
        </div>
    </div>
}
