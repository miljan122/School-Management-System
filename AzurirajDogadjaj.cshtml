@model GimnazijaKM.Models.Dogadjaji

@{
    ViewBag.Title = "Edit Event";
    Layout = "~/Views/Shared/_Layout2.cshtml";
}

<h2>Edit Event</h2>

@using (Html.BeginForm("AzurirajDogadjaj", "Home", FormMethod.Post, new { enctype = "multipart/form-data" }))
{
    @Html.AntiForgeryToken()
    @Html.HiddenFor(model => model.Id)
    @Html.HiddenFor(model => model.Slika)

    <div class="form-group">
        @Html.LabelFor(model => model.Ime)
        @Html.TextBoxFor(model => model.Ime, new { @class = "form-control" })
    </div>

    <div class="form-group">
        @Html.LabelFor(model => model.Datum)
        @Html.TextBoxFor(model => model.Datum, new { @class = "form-control" })
    </div>

    <div class="form-group">
        @Html.LabelFor(model => model.Opis)
        @Html.TextAreaFor(model => model.Opis, new { @class = "form-control", rows = 3 })
    </div>

    <div class="form-group">
        <label>Upload Nova Slika (opciono)</label>
        <input type="file" name="SlikaUpload" class="form-control" />
    </div>


    if (!string.IsNullOrEmpty(Model.Slika))
    {
        <p>Trenutna slika:</p>
        <img src="@Url.Content("~/Content/slike/" + Model.Slika)" width="120" />
    }
    <br />
    <br />
    <br />
    <br />
    <br />
    <button type="submit" class="btn btn-primary">Save Changes</button>
}
