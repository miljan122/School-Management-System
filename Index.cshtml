

@{
    ViewBag.Title = "Home Page";
}

<style>

    .grayscale-hover {
        filter: grayscale(100%);
        transition: filter 0.3s ease;
    }

        .grayscale-hover:hover {
            filter: grayscale(0%);
        }
</style>



<div id="gimSlider" class="carousel slide mb-5" data-bs-ride="carousel">
    <div class="carousel-inner">

        <!-- Slide 1 -->
        <div class="carousel-item active">
            <img src="@(@Model.Slider?.Slika1 ?? "/Content/slike/default1.jpg")" class="d-block w-100" alt="..." style="object-fit: cover; height: 500px;">
            <div class="carousel-caption d-none d-md-block bg-dark bg-opacity-50 rounded p-3">
                <h3 class="text-warning">Гимназија ИТ - Смер</h3>
                <p>Где знање почиње и успех се гради.</p>
                <a href="@Url.Action("ItUcenici", "Home")" class="btn btn-warning">Види Више</a>
            </div>
        </div>

        <!-- Slide 2 -->
        <div class="carousel-item">
            <img src="@(@Model.Slider?.Slika2 ?? "/Content/slike/default2.jpg")" class="d-block w-100" alt="..." style="object-fit: cover; height: 500px;">
            <div class="carousel-caption d-none d-md-block bg-dark bg-opacity-50 rounded p-3">
                <h3 class="text-warning">Гимназија Математички - Смер</h3>
                <p>Традиционалне вредности и савремено образовање.</p>
                <a href="@Url.Action("MatematickiSmer", "Home")" class="btn btn-warning">Види Више</a>
            </div>
        </div>

        <!-- Slide 3 -->
        <div class="carousel-item">
            <img src="@(@Model.Slider?.Slika3 ?? "/Content/slike/default3.jpg")" class="d-block w-100" alt="..." style="object-fit: cover; height: 500px;">
            <div class="carousel-caption d-none d-md-block bg-dark bg-opacity-50 rounded p-3">
                <h3 class="text-warning">Гимназија Језички - Смер</h3>
                <p>Постани део успешне заједнице ученика и професора.</p>
                <a href="@Url.Action("JezickiSmer", "Home")" class="btn btn-warning">Види Више</a>
            </div>
        </div>

    </div>



    <!-- Prev/Next kontrole -->
    <button class="carousel-control-prev" type="button" data-bs-target="#gimSlider" data-bs-slide="prev">
        <span class="carousel-control-prev-icon" style="filter: invert(0%);" aria-hidden="true"></span>
        <span class="visually-hidden">Prethodni</span>
    </button>

    <button class="carousel-control-next" type="button" data-bs-target="#gimSlider" data-bs-slide="next">
        <span class="carousel-control-next-icon" style="filter: invert(0%);" aria-hidden="true"></span>
        <span class="visually-hidden">Sledeći</span>
    </button>
</div>
<hr />
<!-- LAST NEWS -->
@{
    int ukupanBrojVesti = Model.Vesti.Count;
    int ukupanBrojDogadjaja = Model.Events.Count;
}

<section class="container py-5">
    <h2 class="text-center mb-4" style="color: #ffaa00; text-shadow: 3px 3px 6px rgba(0, 0, 50, 0.8); font-weight: bold; font-size: 2.5rem;">
        Последње вести
    </h2>

    <div id="newsCarousel" class="carousel slide" data-bs-ride="carousel">
        <div class="carousel-inner">

            @{
                bool firstSlide = true;
                for (int i = 0; i < ukupanBrojVesti; i += 3)
                {
                    <div class="carousel-item @(firstSlide ? "active" : "")">
                        <div class="row justify-content-center">
                            @for (int j = i; j < i + 3 && j < ukupanBrojVesti; j++)
                            {
                                var vest = Model.Vesti[j];
                                <div class="col-md-4 mb-3">
                                    <div class="card h-100 shadow-sm">
                                        <img src="@vest.Slika1" class="card-img-top" style="height: 200px; object-fit: cover;" alt="Vest">
                                        <div class="card-body d-flex flex-column">
                                            <h5 class="card-title">@vest.Naslov</h5>
                                            <p class="card-text">@vest.KratakOpis</p>
                                            <a href="@Url.Action("Detalji", "Home", new { id = vest.Id })" class="btn btn-warning mt-auto">
                                                Види више
                                            </a>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                    firstSlide = false;
                }
            }
        </div>

        <!-- Kontrole -->
        <button class="carousel-control-prev" type="button" data-bs-target="#newsCarousel" data-bs-slide="prev">
            <span class="carousel-control-prev-icon bg-dark rounded-circle" aria-hidden="true"></span>
            <span class="visually-hidden">Претходни</span>
        </button>
        <button class="carousel-control-next" type="button" data-bs-target="#newsCarousel" data-bs-slide="next">
            <span class="carousel-control-next-icon bg-dark rounded-circle" aria-hidden="true"></span>
            <span class="visually-hidden">Следећи</span>
        </button>

        <!-- Tачкице -->
        <div class="carousel-indicators mt-3">
            @{
                int brojTacaka = (int)Math.Ceiling((double)ukupanBrojVesti / 3);
                for (int k = 0; k < brojTacaka; k++)
                {
                    <button type="button" data-bs-target="#newsCarousel" data-bs-slide-to="@k"
                            class="@(k == 0 ? "active bg-dark" : "bg-dark")"
                            aria-current="@(k == 0 ? "true" : null)"
                            aria-label="Слајд @(k + 1)"></button>
                }
            }
        </div>
    </div>
</section>


<hr />

<!-- COMING EVENTS -->
<section class="bg-light py-5">
    <div class="container">
        <h2 class="text-center mb-4" style="color: #ffaa00; text-shadow: 3px 3px 6px rgba(0, 0, 50, 0.8); font-weight: bold; font-size: 2.5rem;">
            Предстојећи догађаји
        </h2>
        <div class="row justify-content-center">
            <div class="col-md-8">
                <ul class="list-group list-group-flush">
                    @foreach (var dogadjaj in Model.Events)
                    {
                        <li class="list-group-item d-flex justify-content-between align-items-center">
                            <span>
                                <strong>@dogadjaj.Ime</strong> – <strong>  @dogadjaj.Datum </strong>
                            </span>
                            <a href="@Url.Action("DetaljiDogadjaja", "Home", new { id = dogadjaj.Id })" class="btn btn-sm btn-outline-primary">Детаљи</a>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </div>
</section>




