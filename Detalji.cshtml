@model GimnazijaKM.Models.Vesti



<style>
    .thumb-img:hover {
        transform: scale(1.05);
        transition: 0.2s ease-in-out;
        box-shadow: 0 0 10px rgba(255, 170, 0, 0.7);
    }

    .active-thumb {
        border: 3px solid #ffaa00 !important;
    }

    #mainImage:hover {
        transform: scale(1.01);
    }
</style>
<div class="container py-5">
    <!-- Naslov -->
    <h2 class="text-center mb-5 text-warning fw-bold display-5" style="text-shadow: 2px 2px 5px rgba(0, 0, 50, 0.8);">
        @Model.Naslov
    </h2>

    <!-- Glavna slika i thumbnailovi -->
    <div class="row justify-content-center">
        <div class="col-12 col-lg-10">
            <div class="text-center mb-4">
                <img id="mainImage" src="@Model.Slika1" class="img-fluid rounded shadow-lg"
                     style="max-height: 500px; width: 100%; object-fit: cover; transition: 0.4s;" alt="Glavna slika" />
            </div>
            <div class="d-flex justify-content-center gap-3 flex-wrap">
                @if (!string.IsNullOrEmpty(Model.Slika1))
                {
                    <img src="@Model.Slika1" class="img-thumbnail thumb-img rounded shadow-sm active-thumb"
                         style="width: 100px; height: 100px; object-fit: cover; cursor: pointer;" data-img="@Model.Slika1" />
                }
                @if (!string.IsNullOrEmpty(Model.Slika2))
                {
                    <img src="@Model.Slika2" class="img-thumbnail thumb-img rounded shadow-sm"
                         style="width: 100px; height: 100px; object-fit: cover; cursor: pointer;" data-img="@Model.Slika2" />
                }
                @if (!string.IsNullOrEmpty(Model.Slika3))
                {
                    <img src="@Model.Slika3" class="img-thumbnail thumb-img rounded shadow-sm"
                         style="width: 100px; height: 100px; object-fit: cover; cursor: pointer;" data-img="@Model.Slika3" />
                }
            </div>
        </div>
    </div>

    <!-- Opis i informacije -->
    <div class="row mt-5">
        <div class="col-md-8 mx-auto">
            <div class="mb-4">
                <h5 class="text-secondary fw-bold">Opis</h5>
                <p style="font-size: 1.1rem; text-align: justify;">@Model.PunOpis</p>
            </div>
            <div class="bg-light p-4 rounded shadow-sm">
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <strong>Аутор:</strong><br><em>@Model.Autor</em>
                    </div>
                    <div class="col-md-6 mb-3">
                        <strong>Категорија:</strong><br><em>@Model.Kategorija</em>
                    </div>
                    <div class="col-md-6 mb-3">
                        <strong>Таг:</strong><br><em>@Model.Tag</em>
                    </div>
                    <div class="col-md-6 mb-3">
                        <strong>Креирано:</strong><br><em>@Model.KreiranoUFormatted</em>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- JS za zamenu glavne slike i isticanje thumbnaila -->
<script>
    const thumbs = document.querySelectorAll('.thumb-img');
    const mainImage = document.getElementById('mainImage');

    thumbs.forEach(thumb => {
        thumb.addEventListener('click', function () {
            mainImage.src = this.getAttribute('data-img');

            // Aktivna granica
            thumbs.forEach(t => t.classList.remove('active-thumb'));
            this.classList.add('active-thumb');
        });
    });
</script>
