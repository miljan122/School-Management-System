@model GimnazijaKM.Models.Dogadjaji

@{
    ViewBag.Title = "Детаљи догађаја";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<!-- Glavni sadržaj događaja -->
<section class="py-5 bg-light">
    <div class="container">
        <div class="row justify-content-center">
            <!-- Ime događaja u vrhu -->
            <div class="col-12 text-center mb-5">
                <h1 class="display-3 fw-bold text-primary" style="font-family: 'Arial', sans-serif; font-size: 3rem;">
                    @Model.Ime
                </h1>
            </div>
        </div>

        <div class="row justify-content-between align-items-center">
            <!-- Leva strana - Opis događaja -->
            <div class="col-md-7 mb-4 mb-md-0">
                <p class="text-muted mb-4" style="font-size: 1.1rem;">
                    <i class="bi bi-calendar-event"></i> <strong>@Model.Datum</strong>
                </p>

                <!-- Opis događaja - ide do slike -->
                <p class="lead" style="font-size: 1.1rem; line-height: 1.8; color: #555;">
                    @Model.Opis
                </p>

                <a href="@Url.Action("Index", "Home")#dogadjaji" class="btn btn-outline-primary mt-3">
                    <i class="bi bi-arrow-left-circle"></i> Назад на догађаје
                </a>
            </div>

            <!-- Desna strana - Okrugla slika -->
            <div class="col-md-4 d-flex justify-content-center mb-4 mb-md-0">
                <img src="~/Content/slike/@Model.Slika" class="img-fluid rounded-circle shadow-lg" alt="Слика догађаја" style="object-fit: cover; height: 300px; width: 300px;">
            </div>
        </div>

        <!-- Sekcija za dodatne informacije -->
        <div class="row mt-5 text-center">
            <div class="col-12">
                <h2 class="display-4 text-primary mb-4" style="font-family: 'Arial', sans-serif; font-size: 2rem;">
                    Зашто не пропустити овај догађај?
                </h2>
                <p class="lead" style="font-size: 1.1rem; color: #333;">
                    Овај догађај је један од најзначајнијих у години, и нуди прилику да будете део нечега посебног. Уживаћете у квалитетном програму, али и у дружењу са људима који деле вашу страст.
                </p>
                <img src="~/Content/slike/logoTransparent-1.png" class="img-fluid mt-4" alt="Пример догађаја" style="max-height: 300px; object-fit: cover;">
            </div>
        </div>
    </div>
</section>
