@model GimnazijaKM.Models.Letopi

@{
    ViewBag.Title = "Izmeni Letopis";
    Layout = "~/Views/Shared/_Layout2.cshtml";
}

<h2>Izmeni Letopis</h2>

@using (Html.BeginForm("IzmeniLetopis", "Home", FormMethod.Post, new { enctype = "multipart/form-data" }))
{
    @Html.AntiForgeryToken()
    @Html.Hidden("Id", Model.Id)

    <div class="form-group mb-3">
        @Html.LabelFor(m => m.Naslov)
        @Html.TextBoxFor(m => m.Naslov, new { @class = "form-control", required = "required" })
    </div>

    <div class="form-group mb-3">
        @Html.LabelFor(m => m.Opis)
        @Html.TextAreaFor(m => m.Opis, new { @class = "form-control", rows = 3, required = "required" })
    </div>

    <div class="form-group mb-3">
        @Html.Label("PDF fajl (opciono, ako želiš novi upload)")
        <input type="file" name="pdfFajl" accept="application/pdf" class="form-control" />
        @if (!string.IsNullOrEmpty(Model.PdfPutanja))
        {
            <p>Trenutni PDF: <a href="@Url.Content(Model.PdfPutanja)" target="_blank">Preuzmi</a></p>
        }
    </div>

    <button type="submit" class="btn btn-primary">Sačuvaj izmene</button>
    <a href="@Url.Action("DodajLetopis", "Home")" class="btn btn-secondary">Odustani</a>
}
